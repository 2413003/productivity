    {
      "id": "mpppfcl7-xp30lgl",
      "parentId": "mpppafir-8kzhks9",
      "text": "Popularized by Italian Marxist philosopher Antonio Gramsci, cultural hegemony explains how a ruling class maintains power not just through violence or physical force, but through ideological control. By shaping a society's culture, beliefs, and values, the ruling group makes their dominance appear \"natural\" or \"common sense\" to the general public. This leads subordinate groups to passively consent to their own domination.",
      "kind": "objective",
      "taskId": "",
      "masked": false,
      "imageUrl": "",
      "imageUpdatedAt": 0,
      "weight": 50,
